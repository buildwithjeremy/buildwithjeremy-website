# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API Key (for purchase notifications)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# DataForSEO API (for keyword research scripts)
# Get from https://dataforseo.com/apis
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_api_password

# Google Search Console API (path to OAuth credentials JSON)
# Download from Google Cloud Console → APIs & Services → Credentials
GSC_CREDENTIALS_PATH=~/.config/gsc-credentials.json

# Note: You'll also need to create products and prices in Stripe Dashboard:
# 1. Create three products: "AI Employee Starter", "AI Employee Pro", "AI Employee Agency"
# 2. Add one-time prices: $2,997, $4,497, $6,997
# 3. Copy the price IDs (price_xxx) to src/pages/api/checkout.ts
